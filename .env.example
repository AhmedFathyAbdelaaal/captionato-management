# Captionato Task Manager — local dev environment template
# Copy to .env for local development. In production, set these
# in the Coolify service's Environment Variables panel instead.

# Shared team access password (required)
TEAM_PASSPHRASE=change-me

# Flask session signing key — set to a long random string (required)
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# Gunicorn binding port (optional, defaults to 5000)
PORT=5000

# SQLite file location (optional, defaults to ./data/tasks.db locally
# and /app/data/tasks.db in the container)
# DB_PATH=data/tasks.db
